# Spring Boot doesn't load .env files itself — export these into your shell
# (or use a tool like direnv/dotenv-cli) before running `./gradlew bootRun`.
# None of these are required to run the test suite (`./gradlew test`),
# which runs under the "test" Spring profile and skips Shopify OAuth2 entirely.

# Postgres connection (matches docker-compose.yml's defaults)
DB_URL=jdbc:postgresql://localhost:5432/socktical
DB_USERNAME=socktical
DB_PASSWORD=socktical

# Shopify Customer Account API — from your store's Shopify admin:
# Sales channels > Headless > Customer Account API. Create the application
# there to get a client id/secret and the exact issuer URI to paste below.
SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_ID=
SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_SECRET=
# e.g. https://shopify.com/authentication/<shop_id>
SHOPIFY_CUSTOMER_ACCOUNT_ISSUER_URI=
# The GraphQL endpoint shown alongside the above, e.g.
# https://shopify.com/<shop_id>/account/customer/api/2025-01/graphql
SHOPIFY_CUSTOMER_ACCOUNT_API_URL=

# Where the frontend runs — used for CORS and for post-login/post-logout
# redirects. http://localhost:5173 for the two-process dev workflow (`yarn dev`
# + `bootRun`); set this to the backend's own origin (e.g. http://localhost:8080,
# or your deployed URL) when running the single bundled jar — see the README's
# "Building & running as a single server" section.
FRONTEND_BASE_URL=http://localhost:5173
