# Shopify Storefront API credentials.
# Create a headless channel (Sales channels > Headless) in your Shopify admin,
# or run `shopify app init` for a custom app, to generate a Storefront API
# access token scoped to unauthenticated_read_product_listings /
# unauthenticated_write_checkouts (cart) permissions.

# e.g. your-store.myshopify.com
VITE_SHOPIFY_STORE_DOMAIN=

# Storefront API access token (public, safe for client-side use)
VITE_SHOPIFY_STOREFRONT_TOKEN=

# Optional — defaults to 2025-01 if unset
VITE_SHOPIFY_STOREFRONT_API_VERSION=2025-01
