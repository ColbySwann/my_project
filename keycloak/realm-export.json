{
  "realm": "socktical",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "clients": [
    {
      "clientId": "socktical-backend",
      "name": "Socktical Backend (local dev)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "local-dev-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": ["http://localhost:8080/login/oauth2/code/shopify"],
      "webOrigins": ["http://localhost:5173"],
      "defaultClientScopes": ["openid", "profile", "email"]
    }
  ],
  "users": [
    {
      "username": "jane",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Jane",
      "lastName": "Doe",
      "email": "jane@example.com",
      "credentials": [
        {
          "type": "password",
          "value": "jane",
          "temporary": false
        }
      ]
    }
  ]
}
